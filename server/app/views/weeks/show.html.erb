<% content_for :title, "Weekly trends · Ike" %>
<%# Override the default page width — this page wants a sidebar, so we need
    more breathing room than the standard max-w-3xl. %>
<% content_for :main_class, "max-w-5xl" %>

<%= turbo_stream_from "user_#{current_user.id}_blocks" %>

<h1 class="text-xl font-bold mb-6">Weekly trends</h1>

<div class="lg:flex lg:gap-6 lg:items-start">
  <div class="lg:flex-1 lg:min-w-0">
    <%# Day-of-week header row — shared across every week below, so the
        columns line up and your eye can run vertically down "Wednesday". %>
    <div class="flex items-end gap-2 mb-3">
      <div class="w-28 shrink-0"></div>
      <% WeekLog::DAY_LABELS_LONG.each do |label| %>
        <div class="flex-1 text-center text-xs font-medium text-gray-500"><%= label %></div>
      <% end %>
    </div>

    <div class="space-y-2">
      <% @stream.weeks.each do |week| %>
        <%= render "week", week: week %>
      <% end %>
    </div>
  </div>

  <%# Sticky legend panel — pinned to the right, stays in view as the table
      scrolls past. Hidden on narrow screens to avoid squeezing the grid. %>
  <aside class="hidden lg:block lg:w-44 lg:shrink-0">
    <div class="sticky top-6 bg-white border border-gray-200 rounded-lg p-4 shadow-sm">
      <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Legend</h2>
      <ul class="space-y-2">
        <% Quadrant.all.each do |q| %>
          <li class="flex items-center gap-2 text-xs text-gray-600">
            <span class="w-2.5 h-2.5 rounded-full shrink-0" style="background-color: <%= q.color %>"></span>
            <%= q.label %>
          </li>
        <% end %>
      </ul>
    </div>
  </aside>
</div>
