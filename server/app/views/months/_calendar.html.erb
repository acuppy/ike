<%# Calendar grid for `month` (a MonthLog). DOM id scoped to the year-month so
    broadcasts for one month don't clobber a tab viewing a different one. %>
<div id="month-grid-<%= month.year_month %>">
  <div class="grid grid-cols-7 mb-2">
    <% MonthLog::WEEKDAY_LABELS.each do |label| %>
      <div class="text-center text-xs font-medium text-gray-500 py-1"><%= label %></div>
    <% end %>
  </div>

  <div class="grid grid-cols-7 gap-1">
    <% month.weeks.each do |week| %>
      <% week.each do |day| %>
        <%
          colored = day.in_month && day.has_color?
          fill = if colored
                   "background-color: #{day.majority.color};"
                 elsif day.in_month
                   "background-color: #f3f4f6;" # gray-100 — visible against the page bg
                 else
                   "background-color: #f9fafb;" # gray-50 — blends with page bg for adjacent-month days
                 end
          date_class = if colored
                         "text-white" # readable on top of the saturated quadrant color
                       elsif day.in_month
                         "text-gray-900"
                       else
                         "text-gray-300"
                       end
        %>
        <%= link_to today_path(date: day.date.iso8601),
              class: "aspect-square rounded-md p-2 flex flex-col hover:opacity-90 transition",
              style: fill do %>
          <span class="text-sm font-medium <%= date_class %>">
            <%= day.date.day %>
          </span>
        <% end %>
      <% end %>
    <% end %>
  </div>
</div>
