<% content_for :title, "Check your inbox · Ike" %>

<div class="max-w-sm mx-auto mt-16 text-center">
  <span class="inline-flex items-center justify-center w-12 h-12 mx-auto mb-6 rounded-full bg-emerald-50">
    <svg class="w-6 h-6 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="5" width="18" height="14" rx="2"/>
      <path d="M3 7l9 6 9-6"/>
    </svg>
  </span>
  <h1 class="text-xl font-bold mb-2">Check your inbox</h1>
  <p class="text-gray-600 mb-1">
    We sent a sign-in link to <strong><%= session[:pending_email] %></strong>.
  </p>
  <p class="text-sm text-gray-500">
    Click the link in the email to finish signing in. It works once and expires in 15 minutes.
  </p>

  <p class="text-xs text-gray-400 mt-8">
    Didn't get it? Check spam, or
    <%= link_to "try a different address", login_path, class: "text-blue-600 hover:underline" %>.
  </p>
</div>
