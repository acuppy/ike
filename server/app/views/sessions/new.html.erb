<% content_for :title, "Sign in · Ike" %>

<div class="max-w-sm mx-auto mt-16 text-center">
  <span class="inline-grid grid-cols-2 gap-0.5 w-12 h-12 mx-auto mb-6">
    <span class="bg-slate-400 rounded-sm"></span><span class="bg-emerald-500 rounded-sm"></span>
    <span class="bg-amber-500 rounded-sm"></span><span class="bg-rose-500 rounded-sm"></span>
  </span>
  <h1 class="text-2xl font-bold mb-1">Ike</h1>
  <p class="text-gray-500 mb-8">Your Eisenhower-quadrant time log.</p>

  <%= button_to "/auth/google_oauth2", method: :post, data: { turbo: false },
        class: "w-full flex items-center justify-center gap-3 rounded-lg border border-gray-300 bg-white px-4 py-2.5 font-medium shadow-sm hover:bg-gray-50" do %>
    <svg class="w-5 h-5" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1Z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A11 11 0 0 0 12 23Z"/><path fill="#FBBC05" d="M5.84 14.1a6.6 6.6 0 0 1 0-4.2V7.06H2.18a11 11 0 0 0 0 9.88l3.66-2.84Z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1A11 11 0 0 0 2.18 7.06l3.66 2.84C6.71 7.3 9.14 5.38 12 5.38Z"/></svg>
    Sign in with Google
  <% end %>

  <% if Rails.env.development? %>
    <div class="mt-6 pt-6 border-t border-gray-200">
      <p class="text-xs text-gray-400 mb-2">Development only</p>
      <%= button_to "Sign in as a test user", "/auth/developer", method: :post,
            data: { turbo: false },
            class: "text-sm text-blue-600 hover:underline" %>
    </div>
  <% end %>
</div>
