<% content_for :title, "Sign in · Ike" %>

<div class="max-w-sm mx-auto mt-16 text-center">
  <span class="inline-grid grid-cols-2 gap-0.5 w-12 h-12 mx-auto mb-6">
    <span class="bg-slate-400 rounded-sm"></span><span class="bg-emerald-500 rounded-sm"></span>
    <span class="bg-amber-500 rounded-sm"></span><span class="bg-rose-500 rounded-sm"></span>
  </span>
  <h1 class="text-2xl font-bold mb-1">Ike</h1>
  <p class="text-gray-500 mb-8">Your Eisenhower-quadrant time log.</p>

  <%= form_with url: login_deliver_path, method: :post, class: "space-y-3", local: true do |f| %>
    <% if params[:return_to].present? %>
      <%= hidden_field_tag :return_to, params[:return_to] %>
    <% end %>
    <%= f.email_field :email,
          placeholder: "you@example.com",
          autocomplete: "email",
          required: true,
          autofocus: true,
          class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-base shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500" %>
    <%= f.submit "Email me a sign-in link",
          class: "w-full rounded-lg bg-emerald-500 px-4 py-2.5 text-white font-medium shadow-sm hover:bg-emerald-600 cursor-pointer" %>
  <% end %>

  <p class="text-xs text-gray-400 mt-6">
    No password — we'll email you a link that signs you in. The link expires in 15 minutes.
  </p>

  <% if Rails.env.development? %>
    <div class="mt-8 pt-6 border-t border-gray-200">
      <p class="text-xs text-gray-400 mb-2">Development only</p>
      <%= form_with url: login_dev_path, method: :post, local: true do |f| %>
        <% if params[:return_to].present? %>
          <%= hidden_field_tag :return_to, params[:return_to] %>
        <% end %>
        <%= f.submit "Sign in as you@example.com (instant)",
              class: "text-sm text-blue-600 hover:underline bg-transparent border-none cursor-pointer p-0" %>
      <% end %>
    </div>
  <% end %>
</div>
