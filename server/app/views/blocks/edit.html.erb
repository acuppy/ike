<%= turbo_frame_tag @block do %>
  <%= form_with model: @block, class: "px-3 py-2.5 bg-blue-50 rounded-lg" do |f| %>
    <div class="flex items-center gap-2">
      <span class="text-xs font-mono text-gray-400 w-40 shrink-0 whitespace-nowrap">
        <%= format_time(@block.starts_at) %> – <%= format_time(@block.ends_at) %>
      </span>
      <%= f.select :quadrant,
            Quadrant.all.map { |q| [q.label, q.key] },
            {},
            class: "text-sm rounded border-gray-300 shrink-0" %>
      <%= f.text_field :note, placeholder: "Description",
            class: "flex-1 text-sm rounded border-gray-300" %>
      <%= f.submit "Save", class: "text-sm bg-blue-600 text-white rounded px-3 py-1 cursor-pointer" %>
      <%= link_to "Cancel", (request.referer || root_path),
            data: { turbo_frame: "_top" }, class: "text-sm text-gray-500" %>
    </div>
  <% end %>
<% end %>
