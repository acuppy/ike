<% content_for :title, "All activity · Ike" %>

<h1 class="text-xl font-bold mb-6">All activity</h1>

<% if @blocks.empty? %>
  <div class="text-center py-20 text-gray-400">
    <div class="text-4xl mb-3">▦</div>
    <p>Nothing logged yet</p>
  </div>
<% else %>
  <% @blocks.group_by { |b| b.starts_at.to_date }.each do |date, blocks| %>
    <section class="mb-6">
      <h2 class="text-sm font-semibold text-gray-700 mb-1 px-3"><%= date.strftime("%A, %b %-d") %></h2>
      <div class="divide-y divide-gray-100">
        <% blocks.each do |block| %>
          <%= render "blocks/block", block: block %>
        <% end %>
      </div>
    </section>
  <% end %>
<% end %>
