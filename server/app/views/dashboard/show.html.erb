<% content_for :title, "Today · Ike" %>

<%# Subscribe to live updates for this user's blocks. Broadcasts target the
    stable DOM ids #today-top, #today-bottom, and per-row turbo frames. %>
<%= turbo_stream_from "user_#{current_user.id}_blocks" %>

<%= render "today_top", day: @day %>

<div id="today-entries" class="border-t border-gray-200 divide-y divide-gray-100 mb-6">
  <% @day.blocks.reverse_each do |block| %>
    <%= render "blocks/block", block: block %>
  <% end %>
</div>

<%= render "today_bottom", day: @day %>
